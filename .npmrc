# Teamnest API - Package Manager Config
# Last modified: ${DATE}

# Strict engine enforcement
engine-strict = true

# Version control
save-exact = true
git-tag-version = false

# Security
ignore-scripts = false  # Set true in production
fund = false

# Performance
prefer-dedupe = true
legacy-peer-deps = false

# Ensure production-ready installs in CI
omit = dev