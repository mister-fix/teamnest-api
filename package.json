{
	"name": "teamnest-api",
	"description": "A secure and efficient staff and task management API for the Teamnest application. Providing RESTful endpoints for user authentication, employee management, and other essential features. Equipped with JWT authentication, route protection, and more.",
	"private": true,
	"version": "0.1.1",
	"homepage": "https://github.com/mister-fix/teamnest-api#readme",
	"author": "@mister-fix (https://github.com/mister-fix)",
	"license": "AGPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "https://github.com/mister-fix/teamnest-api.git"
	},
	"keywords": [
		"staff management",
		"task management",
		"project management",
		"Node.js",
		"Express.js",
		"API",
		"REST API"
	],
	"lint-staged": {
		"**/*.{js,ts}": [
			"eslint --fix",
			"prettier --write --ignore-unknown"
		],
		"**/*.{json,jsonc,md,yml,yaml}": [
			"prettier --write --ignore-unknown"
		],
		"!**/.prettierrc": []
	},
	"scripts": {
		"dev": "cross-env NODE_ENV=development nodemon --exec ts-node ./index.ts",
		"build": "tspc",
		"start": "cross-env NODE_ENV=production node ./dist/index.js",
		"prepare": "husky || true",
		"cspell": "cspell .",
		"lint": "eslint . ",
		"lint:fix": "eslint . --fix",
		"prettier": "prettier . \"!.prettierrc\" --write",
		"format": "npm run lint:fix && npm run prettier",
		"plop": "plop"
	},
	"dependencies": {
		"@colors/colors": "^1.6.0",
		"bcrypt": "^5.1.1",
		"chalk": "^5.4.1",
		"compression": "^1.8.0",
		"cors": "^2.8.5",
		"cross-env": "^7.0.3",
		"date-fns": "^4.1.0",
		"dotenv": "^16.4.7",
		"express": "^4.21.2",
		"express-async-errors": "^3.1.1",
		"express-rate-limit": "^7.5.0",
		"express-winston": "^4.2.0",
		"helmet": "^8.0.0",
		"mongoose": "^8.11.0",
		"morgan": "^1.10.0",
		"uuid": "^11.1.0",
		"winston": "^3.17.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.7.1",
		"@commitlint/config-conventional": "^19.7.1",
		"@commitlint/format": "^19.5.0",
		"@eslint/js": "^9.20.0",
		"@types/bcrypt": "^5.0.2",
		"@types/compression": "^1.7.5",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/mongoose": "^5.11.96",
		"@types/morgan": "^1.9.9",
		"@types/node": "^22.13.4",
		"@types/uuid": "^10.0.0",
		"cspell": "^8.17.3",
		"cspell-dictionary": "^8.17.3",
		"eslint": "^9.20.1",
		"eslint-config-prettier": "^10.0.1",
		"eslint-import-resolver-alias": "^1.1.2",
		"eslint-import-resolver-typescript": "^3.8.2",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-jsonc": "^2.19.1",
		"eslint-plugin-n": "^17.15.1",
		"eslint-plugin-prettier": "^5.2.3",
		"eslint-plugin-security": "^3.0.1",
		"eslint-plugin-unused-imports": "^4.1.4",
		"globals": "^15.15.0",
		"husky": "^9.1.7",
		"jsonc-eslint-parser": "^2.4.0",
		"lint-staged": "15.4.3",
		"nodemon": "^3.1.9",
		"plop": "^4.0.1",
		"prettier": "3.5.1",
		"prettier-plugin-organize-imports": "4.1.0",
		"pretty-quick": "4.0.0",
		"ts-node": "^10.9.2",
		"ts-patch": "^3.3.0",
		"tsconfig-paths": "^4.2.0",
		"typescript-eslint": "^8.24.1",
		"typescript-transform-paths": "^3.5.3"
	}
}
