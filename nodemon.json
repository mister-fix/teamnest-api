{
	"watch": ["index.ts", "config", "src"],
	"ext": "ts,js,cjs,mjs,json",
	"exec": "ts-node ./index.ts",
	"env": {
		"NODE_ENV": "development",
		"PORT": 8080
	},
	"verbose": false,
	"legacyWatch": true,
	"ignore": ["node_modules", "dist", "build", "coverage", "*/**/*.md", "tests/", "src/**/*.test.js"]
}
